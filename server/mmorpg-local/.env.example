# Скопируй в .env и поменяй при необходимости (например, если порт занят)
PG_SUPER_USER=postgres
PG_SUPER_PASSWORD=postgres
PG_PORT=5432
REDIS_PORT=6379
# профиль full
SCYLLA_PORT=9042
